/* Estilo para los campos que insertaste en Twig */
select, input[type="text"], textarea {
    border: 1px solid #ccc;
    border-radius: 3px;
    padding: 2px 5px;
    font-family: "Times New Roman", serif; /* Para que combine con el reporte */
    font-size: 0.9em;
    background-color: #fafafa;
}

select:focus, input:focus {
    border-color: #3498db;
    outline: none;
    background-color: #fff;
}

/* Para las etiquetas de los campos */
label {
    font-weight: bold;
    margin-right: 10px;
    color: #444;
}

/* Añade esto al final de tu <STYLE> */
.logo-esquina-izquierda {
    position: absolute !important;
    left: 0 !important;   /* Pegado al borde izquierdo físico */
    top: 0 !important;    /* Pegado al borde superior físico */
    margin: 0;
}

.logo-esquina-derecha {
    position: absolute !important;
    right: 0 !important;  /* Pegado al borde derecho físico */
    top: 0 !important;    /* Pegado al borde superior físico */
    left: auto !important; /* Anula cualquier left previo */
