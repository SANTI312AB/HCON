{% block javascripts %}
   
<script type="text/javascript">
    $(document).ready(function() {
        // Seleccionamos el input por su clase (la que pusimos en el FormType)
        var $selectCie = $('.select2-ajax-cie');

        $('.select2-ajax-cie').select2({
    theme: 'bootstrap4',
    width: '100%',
    placeholder: '🔍 Escriba código o nombre de la enfermedad...',
    allowClear: true,
    minimumInputLength: 2,
    ajax: {
        url: '{{ path("select_cie") }}',
        dataType: 'json',
        delay: 400,
        data: function (params) {
            return {
                q: params.term,
                page: params.page || 1
            };
        },
        processResults: function (data) {
            // No cambiamos nada aquí porque el controlador manda la descripción como ID
            return {
                results: data.results,
                pagination: data.pagination
            };
        },
        cache: true
    },
    language: {
        inputTooShort: function() { return "Ingrese 2 o más caracteres..."; },
        searching: function() { return "Buscando en CIE-10..."; },
        noResults: function() { return "No se encontraron coincidencias"; }
    },
    escapeMarkup: function (markup) { return markup; },
    templateResult: function(repo) {
        if (repo.loading) return repo.text;
        return "<div class='select2-result-cie'>" + repo.text + "</div>";
    },
    templateSelection: function (repo) {
        // Esta es la parte clave: mostrar el texto completo en el input
        return repo.text || repo.id;
    }
});
        // Función para mostrar los resultados en el desplegable
        function formatRepo(repo) {
            if (repo.loading) return repo.text;
            
            // Si el texto viene en formato [CODIGO] DESCRIPCION
            var markup = "<div class='select2-result-cie clearfix'>" +
                         "<div class='select2-result-cie__meta'>" +
                         "<div>" + repo.text + "</div>" +
                         "</div></div>";
            return markup;
        }

        // Función para mostrar el item seleccionado
        function formatRepoSelection(repo) {
            return repo.text || repo.id;
        }

        // --- Lógica para Resaltado de Menú ---
        var op8 = document.getElementById("op8");
        if (op8) {
            op8.style.backgroundColor = "#FDF4BC";
        }
    });
</script>




