<style>
    /* Contenedor principal del menú */
    .medical-menu-container {
        background: #fff;
        border-bottom: 2px solid #007bff;
        margin-bottom: 20px;
        width: 100%;
    }

    /* Scroll horizontal adaptable */
    .nav-scrollable {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto; 
        -webkit-overflow-scrolling: touch; 
        padding: 10px 0;
        /* Soporte para Firefox */
        scrollbar-width: auto; 
        scrollbar-color: #00ffa2 #f1f1f1;
    }

    /* --- CONFIGURACIÓN DEL SCROLL CELESTE Y GRUESO --- */
    .nav-scrollable::-webkit-scrollbar {
        height: 12px; /* Grosor del scroll horizontal */
    }

    .nav-scrollable::-webkit-scrollbar-track {
        background: #f1f1f1; /* Fondo de la barra de scroll */
        border-radius: 10px;
    }

    .nav-scrollable::-webkit-scrollbar-thumb {
        background: #00d4ff; /* Color Celeste */
        border-radius: 10px;
        border: 2px solid #f1f1f1; /* Pequeño borde para que se vea más estilizado */
    }

    .nav-scrollable::-webkit-scrollbar-thumb:hover {
        background: #00b8e6; /* Celeste un poco más oscuro al pasar el mouse */
    }

    /* Estilo de los links */
    .nav-scrollable .nav-link {
        color: #495057;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        white-space: nowrap; 
        padding: 8px 15px;
        border-radius: 4px;
        transition: all 0.3s;
    }

    .nav-scrollable .nav-link:hover {
        background-color: #007bff;
        color: #fff !important;
    }

    /* Resalte para la página actual */
    .nav-scrollable .active-link {
        background-color: #007bff !important; 
        color: #ffffff !important;           
        border-bottom: 3px solid #0056b3;    
        pointer-events: none;                
    }

    /* Adaptabilidad total */
    @media (max-width: 768px) {
        .nav-scrollable .nav-link {
            font-size: 11px;
            padding: 10px 12px;
        }
    }


  
</style>
  
