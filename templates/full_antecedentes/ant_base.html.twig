           Aptitud Médica para el Trabajo
        </a>

        {# N. Retiro: Solo si es Ocupacional y motivo es Salida #}
        {% if not esMedica and esSalida %}
            <a class="nav-link {{ route == 'retiro_edit' ? 'active-link' }} text-danger" 
               href="{{ path('retiro_edit', {p: paciente.id, id: consulta.id}) }}">
               Evaluación de Retiro
            </a>
        {% endif %}

      

    </nav>
</div>


<script>
document.addEventListener("DOMContentLoaded", function () {

    const nav = document.querySelector('.nav-scrollable');
    const activeTab = document.querySelector('.active-link');

    if (!nav) return;

    // Restaurar scroll previo
    const savedScroll = localStorage.getItem("medicalNavScroll");
    if (savedScroll !== null) {
        nav.scrollLeft = parseInt(savedScroll);
    }

    // Centrar pestaña activa si existe
    if (activeTab) {
        activeTab.scrollIntoView({ 
            behavior: 'auto', 
            inline: 'center', 
            block: 'nearest' 
        });
    }

    // Guardar posición antes de salir
    nav.addEventListener("click", function () {
        localStorage.setItem("medicalNavScroll", nav.scrollLeft);
    });

});
</script>
  














 

