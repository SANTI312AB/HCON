{# H. ACTIVIDAD LABORAL / INCIDENTES / ACCIDENTES / ENFERMEDADES OCUPACIONALES #}
<h5 class="header-purple-a">H. ACTIVIDAD LABORAL / INCIDENTES / ACCIDENTES / ENFERMEDADES OCUPACIONALES</h5>
<p class="small-label" style="background-color: #c8e6c9; padding: 2px; border: 1px solid #000; margin-bottom: 0; font-weight: bold;">
    ANTECEDENTES DE EMPLEOS ANTERIORES Y/O TRABAJO ACTUAL
</p>

{# Definimos los mismos grupos de riesgo para consistencia #}
{% set g_fis = ['Temperaturas altas', 'Temperaturas bajas', 'Radiacion Ionizante', 'Radiacion No Ionizante', 'Ruido', 'Vibracion', 'Iluminacion', 'Ventilacion', 'Fluido electrico'] %}
{% set g_mec = ['Atrapamiento entre maquinas', 'Atrapamiento entre superficies', 'Atrapamiento entre objetos', 'Caida de objetos', 'Caidas al mismo nivel', 'Caidas a diferente nivel', 'Contacto electrico', 'Contacto con superficies de trabajos', 'Proyeccion de partículas –fragmentos', 'Proyeccion de fluidos', 'Pinchazos', 'Cortes', 'Atropellamientos por vehiculos', 'Choques / Colision vehicular'] %}
{% set g_qui = ['Solidos', 'Polvos', 'Humos', 'liquidos', 'vapores', 'Aerosoles', 'Neblinas', 'Gaseosos'] %}
{% set g_bio = ['Virus', 'Hongos', 'Bacterias', 'Parasitos', 'Exposicion a vectores', 'Exposicion a animales selvaticos'] %}
{% set g_erg = ['Manejo manual de cargas', 'Movimiento repetitivos', 'Posturas forzadas', 'Trabajos con PVD'] %}
{% set g_psi = ['Monotonia del trabajo', 'Sobrecarga laboral', 'Minuciosidad de la tarea', 'Alta responsabilidad', 'Autonomia  en la toma de decisiones', 'Supervision y estilos de dirección deficiente', 'Conflicto de rol', 'Falta de Claridad en las funciones', 'Incorrecta distribución del trabajo', 'Turnos rotativos', 'Relaciones interpersonales', 'Inestabilidad laboral'] %}

<table class="table-riesgos" style="width: 100%; border-collapse: collapse; font-size: 0.55rem; border: 1px solid #000;">
    <thead>
        <tr class="label-green-a">
            <th rowspan="2" style="width: 14%; border: 1px solid #000;">CENTRO DE TRABAJO</th>
            <th rowspan="2" style="width: 14%; border: 1px solid #000;">PUESTO Y ACTIVIDADES</th>
            <th colspan="6" style="border: 1px solid #000;">RIESGOS (Marcar con X)</th>
            <th colspan="2" style="border: 1px solid #000;">TRABAJO</th>
            <th colspan="2" style="border: 1px solid #000;">EVENTOS</th>
            <th style="width: 12%; border: 1px solid #000;">OBSERVACIONES</th>
        </tr>
        <tr class="label-green-a" style="font-size: 0.45rem;">
            <th style="border: 1px solid #000;">FÍS.</th>
            <th style="border: 1px solid #000;">QUÍM.</th>
            <th style="border: 1px solid #000;">BIOL.</th>
            <th style="border: 1px solid #000;">MEC.</th>
            <th style="border: 1px solid #000;">ERG.</th>
            <th style="border: 1px solid #000;">PSIC.</th>
            <th style="border: 1px solid #000;">TIEMPO</th>
            <th style="border: 1px solid #000;">ACTUAL</th>
            <th style="border: 1px solid #000;">ACCID.</th>
            <th style="border: 1px solid #000;">ENFERM.</th>
            <th style="border: 1px solid #000;">DETALLES</th>
        </tr>
    </thead>
    <tbody>
        {% for ant in antl %}
            {% set r = ant.riesgo|default([]) %}
            
            {# Verificación de categorías #}
            {% set hF = false %}{% for v in r %}{% if v in g_fis %}{% set hF = true %}{% endif %}{% endfor %}
            {% set hQ = false %}{% for v in r %}{% if v in g_qui %}{% set hQ = true %}{% endif %}{% endfor %}
            {% set hB = false %}{% for v in r %}{% if v in g_bio %}{% set hB = true %}{% endif %}{% endfor %}
            {% set hM = false %}{% for v in r %}{% if v in g_mec %}{% set hM = true %}{% endif %}{% endfor %}
            {% set hE = false %}{% for v in r %}{% if v in g_erg %}{% set hE = true %}{% endif %}{% endfor %}
            {% set hP = false %}{% for v in r %}{% if v in g_psi %}{% set hP = true %}{% endif %}{% endfor %}

            <tr style="text-align: center;">
                <td class="value-cell-a" style="border: 1px solid #000; padding: 3px;">
                    {{ ant.empresa|upper|default('N/A') }}
                </td>
                <td class="value-cell-a" style="border: 1px solid #000; padding: 3px; text-align: left;">
                    <strong>{{ ant.puestotrabajo|upper }}</strong><br>
                    <span style="font-size: 0.5rem; color: #555;">{{ ant.actividades }}</span>
                </td>
                
                {# Columnas de Riesgos #}
                <td style="border: 1px solid #000;">{{ hF ? 'X' : '' }}</td>
                <td style="border: 1px solid #000;">{{ hQ ? 'X' : '' }}</td>
                <td style="border: 1px solid #000;">{{ hB ? 'X' : '' }}</td>
                <td style="border: 1px solid #000;">{{ hM ? 'X' : '' }}</td>
                <td style="border: 1px solid #000;">{{ hE ? 'X' : '' }}</td>
                <td style="border: 1px solid #000;">{{ hP ? 'X' : '' }}</td>

                {# Tiempo y Actual #}
                <td style="border: 1px solid #000;">{{ ant.tiempotrabajo|default('—') }}</td>
                <td style="border: 1px solid #000;">{{ loop.first ? 'X' : '' }}</td>

                {# Eventos #}
                <td style="border: 1px solid #000;">{{ ant.actrabajo == 'SÍ' ? 'X' : '' }}</td>
                <td style="border: 1px solid #000;">{{ ant.enferemedad == 'SÍ' ? 'X' : '' }}</td>

                {# Observaciones Detalladas #}
                <td style="border: 1px solid #000; text-align: left; padding: 3px; font-size: 0.45rem; line-height: 1;">
                    {% if ant.descripcionaccidentes %}
                        <strong>ACC:</strong> {{ ant.fechaaccidente ? ant.fechaaccidente|date('d/m/y') : '' }} - {{ ant.descripcionaccidentes }}<br>
                    {% endif %}
                    {% if ant.descripcionemfermedad %}
                        <strong>ENF:</strong> {{ ant.fechaenfermedad ? ant.fechaenfermedad|date('d/m/y') : '' }} - {{ ant.descripcionemfermedad }}<br>
                    {% endif %}
                    {{ ant.observaciones }}
                    {% if ant.actextra %}<br><strong>EXTRA:</strong> {{ ant.actextra }}{% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="13" style="border: 1px solid #000; padding: 10px; color: #666; font-style: italic;">
                    No se registran antecedentes laborales previos.
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>