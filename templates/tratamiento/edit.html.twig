{% extends 'base.html.twig' %}

{% block title %}Edit Tratamiento{% endblock %}

{% block body %}
<style>
        /* 1. Controla la altura del despliegue y activa el scroll */
       /* Estilo para las etiquetas seleccionadas */

    /* Recuperar y personalizar el scroll de los resultados */
    .select2-results__options {
        max-height: 250px !important; /* Ajusta la altura máxima a tu gusto */
        overflow-y: auto !important;  /* Forza la aparición del scroll vertical */
    }

    /* Estilizar la barra de scroll para que sea más moderna (opcional) */
    .select2-results__options::-webkit-scrollbar {
        width: 8px;
    }
    .select2-results__options::-webkit-scrollbar-track {
        background: #f1f1f1;
    }
    .select2-results__options::-webkit-scrollbar-thumb {
        background: #007bff;
        border-radius: 4px;
    }

    /* Estilo para las etiquetas (tags) seleccionadas para que no rompan el layout */
    .select2-container--bootstrap4 .select2-selection--multiple {
        min-height: 38px !important;
        height: auto !important;
        padding-bottom: 5px;
    }

    .select2-container--bootstrap4 .select2-selection--multiple .select2-selection__choice {
        background-color: #007bff !important;
        border: none !important;
        color: white !important;
        margin-top: 5px !important;
        padding: 2px 10px !important;
    }

    .select2-dropdown {
    max-height: 300px;
    overflow: hidden;
}

.select2-results__options {
    max-height: 250px !important;
    overflow-y: auto !important;
}

.select2-container--bootstrap4 .select2-selection--multiple::after {
    content: "\f067"; /* icono plus */
    font-family: "Font Awesome 5 Free";
    font-weight: 900;
    color: #007bff;
    position: absolute;
    right: 10px;
    top: 8px;
    font-size: 14px;
    pointer-events: none;
}
</style>
<div class="card-body p-5 bg-white rounded">
    <h5 class="text-primary">Editar Tratamiento</h5>
    <h6>Paciente:  <b>{{paciente.pnombre}} {{paciente.snombre}} {{paciente.papellido}} {{paciente.sapellido}}</h6></b>
{% for flash_message in app.session.flashbag.get('exito') %}
<div class="alert alert-success" role="alert">
       {{ flash_message }}
</div>
{% endfor %}
    {{ include('tratamiento/_form.html.twig', {'button_label': 'Actualizar'}) }}
</p>
 <a href="{{ path('tratamiento_new', {p:paciente.id ,d: diagnostico.id,c:consulta.id}) }}">
 <button class="btn btn-block btn-outline-primary btn-sm">
<i class="fas fa-chevron-left"> Regresar a la lista de Tratamientos</i>
</button>
</a>

</div>

{% endblock %}


{% block javascripts %}

<script type="text/javascript">
    $(document).ready(function() {
    $('.select2-ajax-medicamentos').each(function() {
        var $select = $(this);

        $select.select2({
            theme: 'bootstrap4',
            language: "es",
            allowClear: true,
            placeholder: '🔍 Escriba el nombre o código...',
            minimumInputLength: 3,
            ajax: {
                url: '{{ path("medicamentos_data") }}',
                dataType: 'json',
                delay: 400,
                data: function (params) {
                    return {
                        "search": { "value": params.term }, 
                        "start": 0,
                        "length": 20 
                    };
                },
                processResults: function (data) {
                    return {
                        results: $.map(data.data, function (item) {
                            return {
                                id: item.id,
                                // Importante: el 'text' debe ser igual al choice_label del PHP
                                text: "[" + item.codigo + "] " + item.descripcion
                            };
                        })
                    };
                },
                cache: true
            }
        });

        // LÓGICA DE EDICIÓN:
        // Si el select ya tiene una opción cargada por Symfony (EntityType), 
        // Select2 la tomará automáticamente como valor inicial.
    });
});
</script>

 


  

   {% endblock %}
